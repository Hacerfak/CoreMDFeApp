<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:CoreMDFe.Desktop.ViewModels"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    x:Class="CoreMDFe.Desktop.Views.EmissaoView"
    x:DataType="vm:EmissaoViewModel">

    <Grid RowDefinitions="Auto, *, Auto" Margin="20">
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="20"
            BoxShadow="0 2 10 0 #10000000" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                <TextBlock Text="1. Documentos"
                    FontWeight="{Binding IsPasso1, StringFormat='Bold|Normal'}"
                    Foreground="{Binding IsPasso1, StringFormat='#673AB7|Gray'}" />
                <TextBlock Text=">" Foreground="#E0E0E0" />
                <TextBlock Text="2. Roteiro"
                    FontWeight="{Binding IsPasso2, StringFormat='Bold|Normal'}"
                    Foreground="{Binding IsPasso2, StringFormat='#673AB7|Gray'}" />
                <TextBlock Text=">" Foreground="#E0E0E0" />
                <TextBlock Text="3. Transporte"
                    FontWeight="{Binding IsPasso3, StringFormat='Bold|Normal'}"
                    Foreground="{Binding IsPasso3, StringFormat='#673AB7|Gray'}" />
                <TextBlock Text=">" Foreground="#E0E0E0" />
                <TextBlock Text="4. Envio"
                    FontWeight="{Binding IsPasso4, StringFormat='Bold|Normal'}"
                    Foreground="{Binding IsPasso4, StringFormat='#673AB7|Gray'}" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1">
            <Border Background="White" CornerRadius="8" Padding="30" BoxShadow="0 2 10 0 #05000000">
                <Panel>
                    <StackPanel IsVisible="{Binding IsPasso1}" Spacing="20">
                        <TextBlock Text="Documentos Vinculados (NF-e / CT-e)" FontSize="22"
                            FontWeight="SemiBold" Foreground="#333" />

                        <Border Background="#E3F2FD" CornerRadius="8" Padding="20"
                            BorderBrush="#90CAF9" BorderThickness="1">
                            <StackPanel Spacing="15">
                                <CheckBox
                                    Content="A viagem terá Carregamento Posterior (Iniciar MDF-e SEM Notas Fiscais)"
                                    IsChecked="{Binding IsCarregamentoPosterior}"
                                    FontWeight="Bold" Foreground="#1565C0" />
                            </StackPanel>
                        </Border>

                        <StackPanel IsVisible="{Binding !IsCarregamentoPosterior}" Spacing="15">
                            <TextBlock
                                Text="Faça o upload dos XMLs das notas. O sistema calculará os totais automaticamente."
                                Foreground="Gray" />
                            <Button Content="Procurar XMLs"
                                Command="{Binding ProcurarDocumentosCommand}" Classes="Outline"
                                Foreground="#673AB7" BorderBrush="#673AB7"
                                HorizontalAlignment="Left" Padding="20,10" />

                            <Grid ColumnDefinitions="*,*,*,*" Margin="0,10">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Qtd NF-e" Foreground="Gray" />
                                    <TextBlock Text="{Binding QuantidadeNFe}" FontSize="24"
                                        FontWeight="Bold" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Qtd CT-e" Foreground="Gray" />
                                    <TextBlock Text="{Binding QuantidadeCTe}" FontSize="24"
                                        FontWeight="Bold" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Peso Total (KG)" Foreground="Gray" />
                                    <TextBlock Text="{Binding PesoTotalCarga}" FontSize="24"
                                        FontWeight="Bold" />
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="Valor Total (R$)" Foreground="Gray" />
                                    <TextBlock Text="{Binding ValorTotalCarga}" FontSize="24"
                                        FontWeight="Bold" />
                                </StackPanel>
                            </Grid>

                            <ListBox ItemsSource="{Binding DocumentosFiscais}" Height="450"
                                Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8F9FA" BorderBrush="#E0E0E0"
                                            BorderThickness="1"
                                            CornerRadius="6" Padding="15,10" Margin="0,0,0,8">
                                            <Grid ColumnDefinitions="Auto, *, Auto">

                                                <Border Grid.Column="0" Background="#EDE7F6"
                                                    BorderBrush="#D1C4E9" BorderThickness="1"
                                                    CornerRadius="4" Padding="12,6"
                                                    Margin="0,0,15,0" VerticalAlignment="Center">
                                                    <TextBlock
                                                        Text="{Binding Tipo, StringFormat='Mod. {0}'}"
                                                        FontWeight="Bold" Foreground="#673AB7"
                                                        FontSize="13" />
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center" Spacing="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <TextBlock Text="Nº" FontWeight="SemiBold"
                                                            Foreground="#333" FontSize="14" />
                                                        <TextBlock Text="{Binding Numero}"
                                                            FontWeight="Bold" Foreground="#333"
                                                            FontSize="14" />
                                                        <TextBlock Text="Série"
                                                            FontWeight="SemiBold" Foreground="#333"
                                                            FontSize="14" Margin="10,0,0,0" />
                                                        <TextBlock Text="{Binding Serie}"
                                                            FontWeight="Bold" Foreground="#333"
                                                            FontSize="14" />
                                                    </StackPanel>

                                                    <TextBlock Text="{Binding NomeDestinatario}"
                                                        FontSize="13" Foreground="#555"
                                                        TextTrimming="CharacterEllipsis"
                                                        ToolTip.Tip="{Binding NomeDestinatario}" />

                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <TextBlock
                                                            Text="{Binding MunicipioCarregamento}"
                                                            FontSize="12" Foreground="#888" />
                                                        <materialIcons:MaterialIcon
                                                            Kind="ArrowRightThin" Width="14"
                                                            Height="14" Foreground="#888" />
                                                        <TextBlock
                                                            Text="{Binding MunicipioDescarga}"
                                                            FontSize="12" Foreground="#888" />
                                                    </StackPanel>
                                                </StackPanel>

                                                <Button Grid.Column="2" Classes="Flat"
                                                    Foreground="#F44336" Padding="10"
                                                    Command="{Binding $parent[UserControl].((vm:EmissaoViewModel)DataContext).RemoverDocumentoCommand}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="Remover Documento">
                                                    <materialIcons:MaterialIcon Kind="DeleteOutline"
                                                        Width="22" Height="22" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsPasso2}" Spacing="20">
                        <TextBlock Text="Configurações e Roteiro" FontSize="22"
                            FontWeight="SemiBold" Foreground="#333" />

                        <Grid ColumnDefinitions="*, 20, *">
                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="UF Origem" FontWeight="SemiBold" FontSize="13" />
                                <ComboBox ItemsSource="{Binding ListaUFs}"
                                    SelectedItem="{Binding UfCarregamento}"
                                    HorizontalAlignment="Stretch"
                                    Theme="{StaticResource OutlineComboBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="5">
                                <TextBlock Text="UF Destino" FontWeight="SemiBold" FontSize="13" />
                                <ComboBox ItemsSource="{Binding ListaUFs}"
                                    SelectedItem="{Binding UfDescarregamento}"
                                    HorizontalAlignment="Stretch"
                                    Theme="{StaticResource OutlineComboBox}" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*, 20, *, 20, *">
                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="Tipo Emitente" FontWeight="SemiBold" FontSize="13" />
                                <ComboBox ItemsSource="{Binding ListaTiposEmitente}"
                                    SelectedIndex="{Binding TipoEmitenteIndex}"
                                    HorizontalAlignment="Stretch"
                                    Theme="{StaticResource OutlineComboBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="5">
                                <TextBlock Text="Tipo Transportador" FontWeight="SemiBold"
                                    FontSize="13" />
                                <ComboBox ItemsSource="{Binding ListaTiposTransportador}"
                                    SelectedIndex="{Binding TipoTransportadorIndex}"
                                    HorizontalAlignment="Stretch"
                                    Theme="{StaticResource OutlineComboBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4" Spacing="5">
                                <TextBlock Text="Modal" FontWeight="SemiBold" FontSize="13" />
                                <ComboBox ItemsSource="{Binding ListaModais}"
                                    SelectedIndex="{Binding ModalSelecionadoIndex}"
                                    HorizontalAlignment="Stretch"
                                    Theme="{StaticResource OutlineComboBox}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsPasso3}" Spacing="20">
                        <TextBlock Text="Dados do Transporte" FontSize="22" FontWeight="SemiBold"
                            Foreground="#333" />

                        <StackPanel IsVisible="{Binding IsModalRodoviario}" Spacing="15">

                            <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1"
                                Padding="20" CornerRadius="8">
                                <StackPanel Spacing="15">
                                    <TextBlock Text="Configuração Básica (Obrigatório)"
                                        FontWeight="Bold" Foreground="#673AB7" FontSize="16" />

                                    <Grid ColumnDefinitions="*, 20, *">
                                        <StackPanel Grid.Column="0" Spacing="5">
                                            <TextBlock Text="Veículo de Tração"
                                                FontWeight="SemiBold"
                                                FontSize="13" />
                                            <ComboBox ItemsSource="{Binding VeiculosDisponiveis}"
                                                SelectedItem="{Binding VeiculoSelecionado}"
                                                HorizontalAlignment="Stretch"
                                                PlaceholderText="Escolha um veículo..."
                                                Theme="{StaticResource OutlineComboBox}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Placa}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="5">
                                            <TextBlock Text="Condutor Principal"
                                                FontWeight="SemiBold"
                                                FontSize="13" />
                                            <ComboBox ItemsSource="{Binding CondutoresDisponiveis}"
                                                SelectedItem="{Binding CondutorSelecionado}"
                                                HorizontalAlignment="Stretch"
                                                PlaceholderText="Escolha o motorista..."
                                                Theme="{StaticResource OutlineComboBox}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Nome}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Padding="15">
                                <StackPanel>
                                    <ToggleButton IsChecked="{Binding IsReboquesAberto}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Classes="Outline" BorderThickness="0"
                                        Background="Transparent"
                                        Foreground="#333">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <materialIcons:MaterialIcon
                                                Kind="{Binding IsReboquesAberto, StringFormat='ChevronUp|ChevronDown'}"
                                                Width="20" Height="20" Foreground="#673AB7" />
                                            <TextBlock
                                                Text="Adicionar Veículos de Reboque (Opcional)"
                                                VerticalAlignment="Center" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </ToggleButton>
                                    <StackPanel IsVisible="{Binding IsReboquesAberto}" Spacing="10"
                                        Margin="0,15,0,0">
                                        <TextBlock
                                            Text="O MDF-e suporta até 3 reboques simultâneos."
                                            FontSize="12" Foreground="Gray" />
                                        <Grid ColumnDefinitions="*, 15, *, 15, *">
                                            <ComboBox Grid.Column="0"
                                                ItemsSource="{Binding VeiculosDisponiveis}"
                                                SelectedItem="{Binding Reboque1Selecionado}"
                                                PlaceholderText="Reboque 1"
                                                HorizontalAlignment="Stretch"
                                                Theme="{StaticResource OutlineComboBox}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Placa}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <ComboBox Grid.Column="2"
                                                ItemsSource="{Binding VeiculosDisponiveis}"
                                                SelectedItem="{Binding Reboque2Selecionado}"
                                                PlaceholderText="Reboque 2"
                                                HorizontalAlignment="Stretch"
                                                Theme="{StaticResource OutlineComboBox}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Placa}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <ComboBox Grid.Column="4"
                                                ItemsSource="{Binding VeiculosDisponiveis}"
                                                SelectedItem="{Binding Reboque3Selecionado}"
                                                PlaceholderText="Reboque 3"
                                                HorizontalAlignment="Stretch"
                                                Theme="{StaticResource OutlineComboBox}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Placa}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Padding="15">
                                <StackPanel>
                                    <ToggleButton IsChecked="{Binding IsSeguroAberto}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Classes="Outline" BorderThickness="0"
                                        Background="Transparent"
                                        Foreground="#333">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <materialIcons:MaterialIcon
                                                Kind="{Binding IsSeguroAberto, StringFormat='ChevronUp|ChevronDown'}"
                                                Width="20" Height="20" Foreground="#673AB7" />
                                            <TextBlock
                                                Text="Seguro da Carga (Opcional / Obrigatório p/ Prestadores)"
                                                VerticalAlignment="Center" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </ToggleButton>
                                    <StackPanel IsVisible="{Binding IsSeguroAberto}" Spacing="10"
                                        Margin="0,15,0,0">
                                        <Grid ColumnDefinitions="*, 15, *">
                                            <StackPanel Grid.Column="0" Spacing="5">
                                                <TextBlock Text="CNPJ Seguradora" FontSize="12"
                                                    FontWeight="SemiBold" Foreground="#666" />
                                                <TextBox Text="{Binding SeguradoraCnpj}"
                                                    PlaceholderText="Ex: 00.000.000/0001-00"
                                                    Classes="Outline"
                                                    Theme="{StaticResource OutlineTextBox}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="5">
                                                <TextBlock Text="Nome da Seguradora" FontSize="12"
                                                    FontWeight="SemiBold" Foreground="#666" />
                                                <TextBox Text="{Binding SeguradoraNome}"
                                                    PlaceholderText="Ex: Porto Seguro S/A"
                                                    Classes="Outline"
                                                    Theme="{StaticResource OutlineTextBox}" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid ColumnDefinitions="*, 15, *">
                                            <StackPanel Grid.Column="0" Spacing="5">
                                                <TextBlock Text="Número da Apólice" FontSize="12"
                                                    FontWeight="SemiBold" Foreground="#666" />
                                                <TextBox Text="{Binding NumeroApolice}"
                                                    Classes="Outline"
                                                    Theme="{StaticResource OutlineTextBox}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="5">
                                                <TextBlock Text="Número da Averbação" FontSize="12"
                                                    FontWeight="SemiBold" Foreground="#666" />
                                                <TextBox Text="{Binding NumeroAverbacao}"
                                                    Classes="Outline"
                                                    Theme="{StaticResource OutlineTextBox}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Padding="15">
                                <StackPanel>
                                    <ToggleButton IsChecked="{Binding IsProdutoPredominanteAberto}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Classes="Outline" BorderThickness="0"
                                        Background="Transparent"
                                        Foreground="#333">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <materialIcons:MaterialIcon
                                                Kind="{Binding IsProdutoPredominanteAberto, StringFormat='ChevronUp|ChevronDown'}"
                                                Width="20" Height="20" Foreground="#673AB7" />
                                            <TextBlock Text="Produto Predominante (Opcional)"
                                                VerticalAlignment="Center" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </ToggleButton>
                                    <StackPanel IsVisible="{Binding IsProdutoPredominanteAberto}"
                                        Spacing="10" Margin="0,15,0,0">
                                        <Grid ColumnDefinitions="*, 15, 2*">
                                            <StackPanel Grid.Column="0" Spacing="5">
                                                <TextBlock Text="Tipo de Carga" FontSize="12"
                                                    FontWeight="SemiBold" Foreground="#666" />
                                                <ComboBox ItemsSource="{Binding ListaTiposCarga}"
                                                    SelectedIndex="{Binding TipoCargaIndex}"
                                                    HorizontalAlignment="Stretch"
                                                    Theme="{StaticResource OutlineComboBox}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="5">
                                                <TextBlock Text="Descrição do Produto" FontSize="12"
                                                    FontWeight="SemiBold" Foreground="#666" />
                                                <TextBox Text="{Binding NomeProdutoPredominante}"
                                                    PlaceholderText="Ex: Soja em grãos"
                                                    Classes="Outline"
                                                    Theme="{StaticResource OutlineTextBox}" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid ColumnDefinitions="*, 15, *">
                                            <TextBox Grid.Column="0" Text="{Binding NcmProduto}"
                                                PlaceholderText="Código NCM (Opcional)"
                                                Classes="Outline"
                                                Theme="{StaticResource OutlineTextBox}" />

                                            <TextBox Grid.Column="2" Text="{Binding CeanProduto}"
                                                PlaceholderText="GTIN / EAN (Opcional)"
                                                Classes="Outline"
                                                Theme="{StaticResource OutlineTextBox}" />
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="8" Padding="15">
                                <StackPanel>
                                    <ToggleButton IsChecked="{Binding IsCiotValePedagioAberto}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Classes="Outline" BorderThickness="0"
                                        Background="Transparent"
                                        Foreground="#333">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <materialIcons:MaterialIcon
                                                Kind="{Binding IsCiotValePedagioAberto, StringFormat='ChevronUp|ChevronDown'}"
                                                Width="20" Height="20" Foreground="#673AB7" />
                                            <TextBlock Text="CIOT e Vale Pedágio / ANTT (Opcional)"
                                                VerticalAlignment="Center" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </ToggleButton>
                                    <StackPanel IsVisible="{Binding IsCiotValePedagioAberto}"
                                        Spacing="10" Margin="0,15,0,0">
                                        <TextBlock Text="Dados do CIOT" FontWeight="Bold"
                                            FontSize="13"
                                            Foreground="#666" Margin="0,5,0,0" />
                                        <Grid ColumnDefinitions="*, 15, *">
                                            <TextBox Grid.Column="0" Text="{Binding Ciot}"
                                                PlaceholderText="Código CIOT" Classes="Outline"
                                                Theme="{StaticResource OutlineTextBox}" />
                                            <TextBox Grid.Column="2" Text="{Binding CpfCnpjCiot}"
                                                PlaceholderText="CPF/CNPJ do Responsável pelo CIOT"
                                                Classes="Outline"
                                                Theme="{StaticResource OutlineTextBox}" />
                                        </Grid>
                                        <Separator Background="#EEEEEE" Margin="0,10" />
                                        <TextBlock Text="Vale Pedágio" FontWeight="Bold"
                                            FontSize="13"
                                            Foreground="#666" />
                                        <Grid ColumnDefinitions="*, 15, *">
                                            <TextBox Grid.Column="0"
                                                Text="{Binding CnpjFornecedorValePedagio}"
                                                PlaceholderText="CNPJ Fornecedor do Pedágio"
                                                Classes="Outline"
                                                Theme="{StaticResource OutlineTextBox}" />
                                            <TextBox Grid.Column="2"
                                                Text="{Binding CnpjPagadorValePedagio}"
                                                PlaceholderText="CNPJ Pagador" Classes="Outline"
                                                Theme="{StaticResource OutlineTextBox}" />
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsPasso4}" Spacing="20">
                        <TextBlock Text="Resumo e Transmissão" FontSize="22" FontWeight="SemiBold"
                            Foreground="#333" IsVisible="{Binding !IsAutorizado}" />

                        <Border Background="#F5F7FA" BorderBrush="#E0E0E0" BorderThickness="1"
                            CornerRadius="8" Padding="20" IsVisible="{Binding !IsAutorizado}">
                            <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, *">

                                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                    Margin="0,0,0,15">
                                    <TextBlock Text="ROTA DA VIAGEM" FontSize="12" FontWeight="Bold"
                                        Foreground="#673AB7" Margin="0,0,0,5" />
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding UfCarregamento}" FontWeight="Bold"
                                            FontSize="18" />
                                        <materialIcons:MaterialIcon Kind="ArrowRightThick"
                                            VerticalAlignment="Center" Foreground="Gray" />
                                        <TextBlock Text="{Binding UfDescarregamento}"
                                            FontWeight="Bold" FontSize="18" />
                                    </StackPanel>
                                    <TextBlock
                                        Text="{Binding ResumoCidadesCarregamento, StringFormat='Origem: {0}'}"
                                        FontSize="12" Foreground="Gray" Margin="0,5,0,0" />
                                    <TextBlock
                                        Text="{Binding ResumoCidadesDescarregamento, StringFormat='Destino: {0}'}"
                                        FontSize="12" Foreground="Gray" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,15">
                                    <TextBlock Text="CARGA E DOCUMENTOS" FontSize="12"
                                        FontWeight="Bold" Foreground="#673AB7" Margin="0,0,0,5" />
                                    <TextBlock
                                        Text="{Binding QuantidadeNFe, StringFormat='NF-e: {0} notas'}"
                                        FontSize="14" Foreground="#333" />
                                    <TextBlock
                                        Text="{Binding QuantidadeCTe, StringFormat='CT-e: {0} notas'}"
                                        FontSize="14" Foreground="#333" />
                                    <TextBlock
                                        Text="{Binding PesoTotalCarga, StringFormat='Peso Total: {0} KG'}"
                                        FontSize="14" FontWeight="SemiBold" Foreground="#333"
                                        Margin="0,5,0,0" />
                                    <TextBlock
                                        Text="{Binding ValorTotalCarga, StringFormat='Valor Total: R$ {0:N2}'}"
                                        FontSize="14" FontWeight="SemiBold" Foreground="#4CAF50" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,15">
                                    <TextBlock Text="VEÍCULO E MOTORISTA" FontSize="12"
                                        FontWeight="Bold" Foreground="#673AB7" Margin="0,0,0,5" />
                                    <TextBlock
                                        Text="{Binding VeiculoSelecionado.Placa, StringFormat='Placa: {0}', FallbackValue='Não informado'}"
                                        FontSize="14" FontWeight="SemiBold" Foreground="#333" />
                                    <TextBlock
                                        Text="{Binding CondutorSelecionado.Nome, StringFormat='Mot: {0}', FallbackValue='Não informado'}"
                                        FontSize="14" Foreground="#333" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border
                            IsVisible="{Binding MensagemProcessamento, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Background="{Binding CorFundoMensagem}"
                            BorderBrush="{Binding CorBordaMensagem}" BorderThickness="1"
                            CornerRadius="8" Padding="15">

                            <Grid ColumnDefinitions="Auto, *">
                                <materialIcons:MaterialIcon Grid.Column="0"
                                    Kind="{Binding IconeMensagem}" Width="24"
                                    Height="24" Foreground="{Binding CorTextoMensagem}"
                                    Margin="0,0,10,0" VerticalAlignment="Center" />

                                <TextBlock Grid.Column="1" Text="{Binding MensagemProcessamento}"
                                    FontSize="14"
                                    FontWeight="SemiBold" Foreground="{Binding CorTextoMensagem}"
                                    VerticalAlignment="Center" TextWrapping="Wrap" />
                            </Grid>

                        </Border>

                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsProcessando}"
                            Foreground="#673AB7" />

                        <StackPanel IsVisible="{Binding IsAutorizado}" Spacing="20"
                            HorizontalAlignment="Center" Margin="0,20,0,0">
                            <materialIcons:MaterialIcon Kind="CheckCircle" Width="80" Height="80"
                                Foreground="#4CAF50" HorizontalAlignment="Center" />
                            <TextBlock Text="✅ MDF-e Autorizado com Sucesso!" FontSize="22"
                                FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center" />

                            <StackPanel Orientation="Horizontal" Spacing="20"
                                HorizontalAlignment="Center" Margin="0,15,0,0">
                                <Button Content="🖨️ IMPRIMIR DAMDFE"
                                    Command="{Binding ImprimirCommand}"
                                    Classes="Primary" Theme="{StaticResource SolidButton}"
                                    Background="#2196F3" Foreground="White" Padding="30,15"
                                    FontWeight="Bold" CornerRadius="8" />

                                <Button Content="➕ NOVA EMISSÃO"
                                    Command="{Binding NovaEmissaoCommand}"
                                    Classes="Outline" BorderBrush="#673AB7" Foreground="#673AB7"
                                    Padding="30,15" FontWeight="Bold" CornerRadius="8" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Panel>
            </Border>
        </ScrollViewer>

        <Grid Grid.Row="2" ColumnDefinitions="Auto, Auto, *, Auto"
            IsVisible="{Binding !IsAutorizado}">

            <Button Grid.Column="0" Content="Cancelar" Command="{Binding CancelarEmissaoCommand}"
                Classes="Flat" Foreground="#F44336" Padding="20,10" Margin="0,0,10,0" />

            <Button Grid.Column="1" Content="Voltar" Command="{Binding VoltarCommand}"
                IsVisible="{Binding !IsPasso1}" Classes="Flat" Foreground="Gray" Padding="20,10" />

            <Button Grid.Column="3" Content="Avançar" Command="{Binding AvancarCommand}"
                IsVisible="{Binding !IsPasso4}" Classes="Primary"
                Theme="{StaticResource SolidButton}" Background="#673AB7" Foreground="White"
                Padding="30,10" CornerRadius="20" />

            <Button Grid.Column="3" Content="Emitir MDF-e" Command="{Binding EmitirCommand}"
                IsVisible="{Binding IsPasso4}" Classes="Primary"
                Theme="{StaticResource SolidButton}" Background="#4CAF50" Foreground="White"
                Padding="30,10" CornerRadius="20" IsEnabled="{Binding !IsProcessando}" />
        </Grid>
    </Grid>
</UserControl>